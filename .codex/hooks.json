{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/guard-memory-write.sh\"",
            "statusMessage": "Checking memory-write guard..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/guard-memory-search.sh\"",
            "statusMessage": "Checking memory-search guard..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/auto-commit-memory.sh\"",
            "statusMessage": "Auto-committing memory entry..."
          }
        ]
      }
    ]
  }
}
